# Supabase-Konfiguration (optional).
# Ohne diese Werte läuft die App rein lokal (localStorage).
# Kopiere die Datei zu .env und trage deine Projektwerte ein
# (Supabase-Dashboard -> Project Settings -> API).
VITE_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
VITE_SUPABASE_ANON_KEY=dein-anon-public-key
